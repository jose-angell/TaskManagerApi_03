## Visual Studio / .NET common ignores
# See https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific
*.suo
*.user
*.userosscache
*.sln.docstates
.env

# Build results
[Bb]in/
[Oo]bj/
out/
artifacts/
.obj/

# Visual Studio Code
.vscode/
.vs/

# Visual Studio
.vs/

# Rider
.idea/
*.sln.iml

# NuGet
*.nupkg
*.snupkg
packages/
.nuget/
project.lock.json
project.fragment.lock.json

# DotCover
*.dotCover

# Resharper
_ReSharper*/
*.ReSharper*

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# IIS Express
/.vs/**/applicationhost.config
/.vs/**/IISExpress.config

# Publish directory
publish/
wwwroot/GeneratedFiles/

# Logs
*.log
TestResults/

# Coverage
coverage*
*.coverage
*.coveragexml

# Database files
*.mdf
*.ldf
*.db
*.sqlite

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
~$*
*.tmp
*.temp

# OneDrive / sync metadata
~*.tmp
*.lnk

# JetBrains local history
.idea/.idea.LocalHistory

# Avoid committing secrets or local settings
appsettings.Development.json
secrets.json

## Additional ignores to avoid committing build artifacts and user-specific files
# Compiled binaries and debug symbols
*.dll
*.exe
*.pdb

# Solution / IDE user files
*.slnx.user
*.sln.cache

# Ignore solution-level packages folders (nested packages/ directories)
**/packages/

# Ignore IDE-created NuGet package directories
.package*/


# Tools
.dotnet/
.tools/
.store/
.vs/

# .NET Aspire (si usa microservicios)
.aspire/

# Playwright / Pruebas de integración
.playwright/
playwright-report/
test-results/

# Node / Frontend (si su proyecto .NET tiene React/Angular/Blasor con npm)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# Archivos de publicación local y contenedores
deploy/
.dockerignore